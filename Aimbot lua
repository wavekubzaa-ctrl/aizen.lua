--[[ 
    PROJECT: UNIVERSAL AIMLOCK (V23 - TARGET INFO)
    PURPOSE: Aimlock with Target Name Notification
    FEATURES: Smooth Lock, Jitter Safe, Target HUD
--]]

if not game:IsLoaded() then game.Loaded:Wait() end

-- // Services //
local _LP = game.Players.LocalPlayer
local _CAMERA = workspace.CurrentCamera
local _RUN = game:GetService("RunService")
local _UIS = game:GetService("UserInputService")
local _TS = game:GetService("TweenService")

-- // Config //
getgenv().AimConfig = {
    Enabled = false,
    Smoothness = 0.12,
    AimPart = "HumanoidRootPart",
    FOV = 200,
    ThemeColor = Color3.fromRGB(255, 45, 45)
}

-- // UI Creation //
local _G = Instance.new("ScreenGui", game.CoreGui)
_G.Name = "BWH_TargetHUD"

-- Main Toggle Button
local _MainBtn = Instance.new("TextButton", _G)
_MainBtn.Size = UDim2.new(0, 60, 0, 60)
_MainBtn.Position = UDim2.new(0.05, 0, 0.3, 0)
_MainBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
_MainBtn.Text = "AIM: OFF"
_MainBtn.TextColor3 = Color3.new(1, 1, 1)
_MainBtn.Font = Enum.Font.GothamBold
_MainBtn.TextSize = 10
_MainBtn.Draggable = true
Instance.new("UICorner", _MainBtn).CornerRadius = UDim.new(1, 0)
Instance.new("UIStroke", _MainBtn).Color = getgenv().AimConfig.ThemeColor

-- Target Notification HUD (ส่วนแสดงชื่อเป้าหมาย)
local _TargetHUD = Instance.new("Frame", _G)
_TargetHUD.Size = UDim2.new(0, 200, 0, 40)
_TargetHUD.Position = UDim2.new(0.5, -100, 0.15, 0) -- แสดงด้านบนกลางหน้าจอ
_TargetHUD.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
_TargetHUD.BackgroundTransparency = 0.4
_TargetHUD.Visible = false
Instance.new("UICorner", _TargetHUD)
Instance.new("UIStroke", _TargetHUD).Color = getgenv().AimConfig.ThemeColor

local _TargetText = Instance.new("TextLabel", _TargetHUD)
_TargetText.Size = UDim2.new(1, 0, 1, 0)
_TargetText.Text = "Locking: None"
_TargetText.TextColor3 = Color3.new(1, 1, 1)
_TargetText.Font = Enum.Font.GothamMedium
_TargetText.TextSize = 14
_TargetText.BackgroundTransparency = 1

-- // Helper Functions //
local function GetClosestPlayer()
    local target, shortestDistance = nil, getgenv().AimConfig.FOV
    local screenCenter = Vector2.new(_CAMERA.ViewportSize.X / 2, _CAMERA.ViewportSize.Y / 2)

    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= _LP and player.Character and player.Character:FindFirstChild(getgenv().AimConfig.AimPart) then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local point, onScreen = _CAMERA:WorldToViewportPoint(player.Character[getgenv().AimConfig.AimPart].Position)
                if onScreen then
                    local distance = (Vector2.new(point.X, point.Y) - screenCenter).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        target = player
                    end
                end
            end
        end
    end
    return target
end

-- // Toggle Logic //
_MainBtn.MouseButton1Click:Connect(function()
    getgenv().AimConfig.Enabled = not getgenv().AimConfig.Enabled
    _MainBtn.Text = getgenv().AimConfig.Enabled and "AIM: ON" or "AIM: OFF"
    _MainBtn.BackgroundColor3 = getgenv().AimConfig.Enabled and getgenv().AimConfig.ThemeColor or Color3.fromRGB(15, 15, 15)
    
    if not getgenv().AimConfig.Enabled then
        _TargetHUD.Visible = false
    end
end)

-- // Main Loop //
local lastTarget = nil

_RUN.RenderStepped:Connect(function()
    if getgenv().AimConfig.Enabled then
        local target = GetClosestPlayer()
        
        if target and target.Character then
            -- ล็อกเป้าหมาย
            local targetPos = target.Character[getgenv().AimConfig.AimPart].Position
            local jitter = (math.random(-10, 10) / 1000)
            _CAMERA.CFrame = _CAMERA.CFrame:Lerp(CFrame.new(_CAMERA.CFrame.Position, targetPos), getgenv().AimConfig.Smoothness + jitter)
            
            -- อัปเดตการแจ้งเตือน
            _TargetHUD.Visible = true
            _TargetText.Text = "Locking: " .. player.DisplayName -- ใช้ชื่อที่ตั้งในเกม
            
            -- ถ้าเปลี่ยนเป้าหมายใหม่ ให้กระพริบไฟแจ้งเตือนเล็กน้อย
            if target ~= lastTarget then
                lastTarget = target
                _TargetText.TextColor3 = getgenv().AimConfig.ThemeColor
                task.delay(0.2, function() _TargetText.TextColor3 = Color3.new(1,1,1) end)
            end
        else
            _TargetHUD.Visible = false
            lastTarget = nil
        end
    end
end)
