        if Config.Aimbot and not Config.SilentBullet then
            local target = GetClosest(Config.AimFOV, Config.AimTeamCheck)
            if target and target.Character:FindFirstChild(Config.AimPart) then
                local lookAt = CFrame.lookAt(Camera.CFrame.Position, target.Character[Config.AimPart].Position)
                Camera.CFrame = Camera.CFrame:Lerp(lookAt, Config.AimSmooth)
            end
        end
        if Config.AutoHeal and IsAlive(LP) and LP.Character.Humanoid.Health < Config.HealThreshold then
            LP.Character.HumanoidRootPart.CFrame = CFrame.new(Config.HealPos)
        end
    end)
end)

