-- // Logic Core //
local function GetHealthColor(hp) return hp > 70 and Color3.new(0,1,0) or (hp > 30 and Color3.new(1,1,0) or Color3.new(1,0,0)) end
local ESP_Objects = {}
local function CreateESP(p)
    local t = Drawing.new("Text"); t.Visible = false; t.Center = true; t.Outline = true; t.Font = 2; t.Size = 13
    local h = Drawing.new("Text"); h.Visible = false; h.Center = true; h.Outline = true; h.Font = 2; h.Size = 11
    ESP_Objects[p] = {Text = t, Health = h}
end
for _, p in pairs(game.Players:GetPlayers()) do if p ~= _LP then CreateESP(p) end end
game.Players.PlayerAdded:Connect(function(p) if p ~= _LP then CreateESP(p) end end)

_RUN.RenderStepped:Connect(function()
    FOVCircle.Visible = getgenv().EliteConfig.AimEnabled
    FOVCircle.Radius = getgenv().EliteConfig.FOV
    FOVCircle.Position = Vector2.new(_CAMERA.ViewportSize.X/2, _CAMERA.ViewportSize.Y/2)

    for p, assets in pairs(ESP_Objects) do
        if getgenv().EliteConfig.ESPEnabled and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local pos, screen = _CAMERA:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if screen then
                local dist = math.floor((_LP.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude)
                local hp = math.floor(p.Character.Humanoid.Health)
                assets.Text.Position = Vector2.new(pos.X, pos.Y - 45); assets.Text.Text = p.DisplayName .. " [" .. dist .. "m]"; assets.Text.Visible = true
                assets.Health.Position = Vector2.new(pos.X, pos.Y - 30); assets.Health.Text = hp .. " HP"; assets.Health.Color = GetHealthColor(hp); assets.Health.Visible = true
            else assets.Text.Visible = false; assets.Health.Visible = false end
        else assets.Text.Visible = false; assets.Health.Visible = false end
    end

    if getgenv().EliteConfig.AimEnabled then
        local target, shortestMag = nil, getgenv().EliteConfig.FOV
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= _LP and p.Character and p.Character:FindFirstChild(getgenv().EliteConfig.AimPart) and p.Character.Humanoid.Health > 0 then
                local pos, screen = _CAMERA:WorldToViewportPoint(p.Character[getgenv().EliteConfig.AimPart].Position)
                if screen then
                    local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(_CAMERA.ViewportSize.X/2, _CAMERA.ViewportSize.Y/2)).Magnitude
                    if mag < shortestMag then shortestMag = mag; target = p end
                end
            end
        end
        if target then
            local tPart = target.Character[getgenv().EliteConfig.AimPart]
            local dist = (_LP.Character.HumanoidRootPart.Position - tPart.Position).Magnitude
            local predictPos = tPart.Position + (target.Character.HumanoidRootPart.AssemblyLinearVelocity * (dist / getgenv().EliteConfig.BulletSpeed) * getgenv().EliteConfig.PredictIntensity)
            _CAMERA.CFrame = _CAMERA.CFrame:Lerp(CFrame.new(_CAMERA.CFrame.Position, predictPos), getgenv().EliteConfig.Smoothness)
        end
    end
end)
