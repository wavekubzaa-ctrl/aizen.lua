-- // Admin Detection Logic //
local function CheckAdmin(p)
    if p:GetRankInGroup(5141014) >= 200 or p:GetRankInGroup(32586675) >= 5 then -- เช็ค Rank ในกลุ่ม Hamburg
        if getgenv().EliteConfig.AdminNotify then
            ShowNotify("⚠️ ADMIN DETECTED: " .. p.Name)
            _STARTERGUI:SetCore("SendNotification", {
                Title = "ELITE WARNING",
                Text = "Admin " .. p.Name .. " joined the game!",
                Duration = 10
            })
        end
    end
end

game.Players.PlayerAdded:Connect(CheckAdmin)
