RS.Heartbeat:Connect(function()
    if Config.AutoShoot then
        local t = GetClosest(Config.ShootFOV, Config.ShootTeamCheck)
        if t then
            local tool = LP.Character and LP.Character:FindFirstChildWhichIsA("Tool")
            if tool then tool:Activate() end
        end
    end
    
    if Config.Aimbot and not Config.SilentBullet then
        local t = GetClosest(Config.AimFOV, Config.AimTeamCheck)
        if t and t.Character[Config.AimPart] then
            local la = CFrame.lookAt(Camera.CFrame.Position, t.Character[Config.AimPart].Position)
            Camera.CFrame = Camera.CFrame:Lerp(la, Config.AimSmooth)
        end
    end
    
    if Config.AutoHeal and IsAlive(LP) and LP.Character.Humanoid.Health < Config.HealThreshold then
        LP.Character.HumanoidRootPart.CFrame = CFrame.new(Config.HealPos)
    end
end)

RS.Heartbeat:Connect(function()
    if Config.CarTuning then
        local h = LP.Character and LP.Character:FindFirstChild("Humanoid")
        local s = h and h.SeatPart
        if s and s:IsA("VehicleSeat") then
            s.MaxSpeed = Config.CarSpeed
            s.Torque = 140000
            if Config.CarGod then
                for _,p in pairs(s.Parent:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
            if Config.CarTurbo and UIS:IsKeyDown(Enum.KeyCode.LeftShift) then
                local f = s.CFrame.LookVector * Config.CarSpeed * 2.2
                s.AssemblyLinearVelocity = Vector3.new(f.X, s.AssemblyLinearVelocity.Y, f.Z)
            end
        end
    end
end)

