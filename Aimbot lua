CreateLabel("--- LICENSE PLATE ---")
local PlateInput = Instance.new("TextBox", Scroll)
PlateInput.Size = UDim2.new(1, -10, 0, 35); PlateInput.BackgroundColor3 = Color3.fromRGB(30, 30, 35); PlateInput.PlaceholderText = "พิมพ์เลขป้าย..."; PlateInput.Text = ""; PlateInput.TextColor3 = Color3.new(1, 1, 1); PlateInput.Font = Enum.Font.SourceSans; Instance.new("UICorner", PlateInput)

local PlateBtn = Instance.new("TextButton", Scroll)
PlateBtn.Size = UDim2.new(1, -10, 0, 35); PlateBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 80); PlateBtn.Text = "CHANGE PLATE"; PlateBtn.TextColor3 = Color3.new(1, 1, 1); PlateBtn.Font = Enum.Font.SourceSansBold; Instance.new("UICorner", PlateBtn)
PlateBtn.MouseButton1Click:Connect(function()
    local text = PlateInput.Text
    local seat = _LP.Character and _LP.Character:FindFirstChild("Humanoid") and _LP.Character.Humanoid.SeatPart
    if seat and seat:IsA("VehicleSeat") then
        local vehicle = seat.Parent
        for _, v in pairs(vehicle:GetDescendants()) do
            if v:IsA("TextLabel") and (v.Parent.Name:lower():find("plate") or v.Name:lower():find("plate")) then
                v.Text = text
            end
        end
        -- Remote Search
        local rem = vehicle:FindFirstChild("Remotes") or vehicle:FindFirstChild("Events")
        if rem then
            for _, ev in pairs(rem:GetChildren()) do
                if ev:IsA("RemoteEvent") and (ev.Name:lower():find("plate") or ev.Name:lower():find("license")) then
                    ev:FireServer(text)
                end
            end
        end
    else
        PlateBtn.Text = "นั่งรถก่อนกด!"; task.wait(1.5); PlateBtn.Text = "CHANGE PLATE"
    end
end)

