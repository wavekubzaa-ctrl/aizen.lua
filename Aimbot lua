-- Drag code (เหมือนเดิม)
local dragging, dragInput, dragStart, startPos
ToggleFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = ToggleFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

ToggleFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        ToggleFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

local function toggleMenu()
    -- Rayfield UI มักอยู่ใน PlayerGui หรือ CoreGui - ลองหา Main frame
    local rayfieldGui = PlayerGui:FindFirstChildWhichIsA("ScreenGui") -- หรือหาโดยชื่อ Rayfield
    if rayfieldGui then
        for _, child in pairs(rayfieldGui:GetDescendants()) do
            if child:IsA("Frame") and child.Name == "Main" then
                child.Visible = not child.Visible
                ToggleFrame.BackgroundColor3 = child.Visible and Color3.fromRGB(0,180,0) or Color3.fromRGB(200,0,0)
                Icon.Text = child.Visible and "✕" or "☰"
                break
            end
        end
    end
end

ToggleFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        toggleMenu()
    end
end)

