    b.Size = UDim2.new(0, 260, 0, 42); b.BackgroundColor3 = Color3.fromRGB(30, 30, 35); b.Text = txt .. ": OFF"; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.GothamBold; Instance.new("UICorner", b)
    
    local function Update()
        b.Text = txt .. (getgenv().EliteV88[key] and ": ON" or ": OFF")
        b.TextColor3 = getgenv().EliteV88[key] and Color3.fromRGB(0, 255, 180) or Color3.new(1,1,1)
