-- // Check Status //
local function IsShootable(p)
    local stats = p:FindFirstChild("leaderstats")
    if stats then
        local wanted = stats:FindFirstChild("Wanted") or stats:FindFirstChild("Bounty") or stats:FindFirstChild("Stars")
        if wanted and wanted.Value > 0 then return true end
    end
    if p.Team and (p.Team.Name:find("Police") or p.Team.Name:find("Sheriff")) then return true end
    return false
end

-- // Auto Shoot Logic //
local lastShoot = 0
local function FireWeapon()
    if tick() - lastShoot > 0.1 then -- หน่วงเวลาเล็กน้อยกันเอ๋อ
        -- จำลองการคลิกเมาส์/กดปุ่มยิง
        mouse1click() 
        lastShoot = tick()
    end
end

-- // Main Loop //
_RUN.RenderStepped:Connect(function()
    -- No Fog
    if getgenv().EliteConfig.NoFog then
        _LIGHTING.FogEnd = 1e6
        _LIGHTING.Atmosphere.Density = 0
    end

    -- Aim & Auto Shoot
    if getgenv().EliteConfig.AimEnabled then
        local target, shortestDist = nil, getgenv().EliteConfig.FOV
        local screenCenter = Vector2.new(_CAMERA.ViewportSize.X/2, _CAMERA.ViewportSize.Y/2)

        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= _LP and p.Character and p.Character:FindFirstChild(getgenv().EliteConfig.AimPart) and IsShootable(p) then
                if p.Character.Humanoid.Health > 0 then
                    local pos, screen = _CAMERA:WorldToViewportPoint(p.Character[getgenv().EliteConfig.AimPart].Position)
                    if screen then
                        local mag = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
                        if mag < shortestDist then shortestDist = mag; target = p end
                    end
                end
            end
        end

        if target then
            local tPart = target.Character[getgenv().EliteConfig.AimPart]
            local dist = (_LP.Character.HumanoidRootPart.Position - tPart.Position).Magnitude
            local finalPos = tPart.Position + (tPart.AssemblyLinearVelocity * (dist / getgenv().EliteConfig.BulletSpeed))
            _CAMERA.CFrame = CFrame.new(_CAMERA.CFrame.Position, finalPos + Vector3.new(0, (dist / 500), 0))
            
            -- ถ้าเปิด Auto Shoot และเป้าอยู่ใกล้จุดกึ่งกลาง (ล็อกติดแล้ว) ให้ยิง
            if getgenv().EliteConfig.AutoShoot and shortestDist < 20 then
                FireWeapon()
            end
        end
    end
end)

-- // Vehicle Boost //
_RUN.Heartbeat:Connect(function()
    if getgenv().EliteConfig.VehicleTune then
        local char = _LP.Character
        if char and char:FindFirstChild("Humanoid") and char.Humanoid.SeatPart then
            local seat = char.Humanoid.SeatPart
            if seat:IsA("VehicleSeat") and seat.Throttle == 1 then
                seat.Parent:TranslateBy(seat.CFrame.LookVector * (getgenv().EliteConfig.SpeedMult / 10))
            end
        end
    end
end)

-- // ESP System //
local function CreateESP(p)
    local box = Drawing.new("Square"); box.Thickness = 1; box.Visible = false
    local txt = Drawing.new("Text"); txt.Size = 16; txt.Outline = true; txt.Center = true; txt.Visible = false
    txt.Color = Color3.new(1, 1, 1)

    _RUN.RenderStepped:Connect(function()
        if getgenv().EliteConfig.ESPEnabled and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local dist = (_LP.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if dist <= getgenv().EliteConfig.MaxDist then
                local pos, screen = _CAMERA:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                if screen then
                    local color = IsShootable(p) and Color3.new(1,0,0) or Color3.new(0,1,1)
                    box.Size = Vector2.new(50, 50); box.Position = Vector2.new(pos.X - 25, pos.Y - 25); box.Color = color; box.Visible = true
                    txt.Position = Vector2.new(pos.X, pos.Y - 50); txt.Text = (IsShootable(p) and "[TARGET]\n" or "") .. p.DisplayName .. "\n[" .. math.floor(dist) .. "m]"; txt.Visible = true
                else box.Visible = false; txt.Visible = false end
            else box.Visible = false; txt.Visible = false end
        else box.Visible = false; txt.Visible = false end
    end)
end
for _, p in pairs(game.Players:GetPlayers()) do if p ~= _LP then CreateESP(p) end end
game.Players.PlayerAdded:Connect(function(p) if p ~= _LP then CreateESP(p) end end)
