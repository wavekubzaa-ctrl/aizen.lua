end)

-- // SILENT BULLET ENGINE (METATABLE HOOK) //
local mt = getrawmetatable(game); setreadonly(mt, false); local oldNamecall = mt.__namecall
mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if getgenv().DarkElite.SilentBullet and method == "FindPartOnRayWithIgnoreList" then
        local target = GetClosestTarget(getgenv().DarkElite.SilentFOV)
        if target and target.Character:FindFirstChild(getgenv().DarkElite.SilentPart) then
            args[1] = Ray.new(_CAMERA.CFrame.Position, (target.Character[getgenv().DarkElite.SilentPart].Position - _CAMERA.CFrame.Position).Unit * 1000)
            return oldNamecall(self, unpack(args))
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

