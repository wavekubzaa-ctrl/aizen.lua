    AimEnabled = false,
    ESPEnabled = false,
    AimPart = "HumanoidRootPart",
    FOV = 200,
    NoFog = false,
    MaxDist = 2000,
    CurrentMode = "G36",
    BulletSpeed = 850,
    -- Vehicle Config
    VehicleTune = false,
    SpeedMult = 1.5, -- ตัวคูณความเร็ว (แนะนำไม่เกิน 2.0 เพื่อความปลอดภัย)
    ThemeColor = Color3.fromRGB(0, 255, 150)
}

