local function CreateLabel(text)
    local l = Instance.new("TextLabel", Scroll)
    l.Size = UDim2.new(1, -10, 0, 25); l.BackgroundTransparency = 1; l.Text = text; l.TextColor3 = Color3.fromRGB(200, 200, 200); l.Font = Enum.Font.SourceSansBold; l.TextSize = 14
end

local function AddToggle(text, config_key)
    local b = Instance.new("TextButton", Scroll)
    b.Size = UDim2.new(1, -10, 0, 35); b.BackgroundColor3 = Color3.fromRGB(40, 40, 45); b.Text = text .. (getgenv().EliteConfig[config_key] and ": ON" or ": OFF"); b.TextColor3 = Color3.new(1, 1, 1); b.Font = Enum.Font.SourceSansBold; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        getgenv().EliteConfig[config_key] = not getgenv().EliteConfig[config_key]
        b.Text = text .. (getgenv().EliteConfig[config_key] and ": ON" or ": OFF")
    end)
end

