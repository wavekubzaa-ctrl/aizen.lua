-- Hooks (ปรับ FireRate เป็น 2x)
local mt = getrawmetatable(game)
setreadonly(mt, false)
local oldName = mt.__namecall
mt.__namecall = newcclosure(function(self, ...)
    local a = {...}
    local m = getnamecallmethod()
    if Config.SilentBullet and self == WS and m == "Raycast" then
        local dir = a[2]
        if dir.Magnitude < 50 then return oldName(self, ...) end
        local t = GetClosest(Config.SilentFOV, Config.SilentTeamCheck, Config.SilentPart)
        if t and math.random(1,100) <= Config.HitChance then
            local tp = t.Character[Config.SilentPart].Position + (t.Character.HumanoidRootPart.Velocity * 0.12)
            a[2] = (tp - a[1]).Unit * dir.Magnitude
        end
    end
    return oldName(self, unpack(a))
end)

local oldIndex = mt.__index
mt.__index = newcclosure(function(self, k)
    if not checkcaller() then
        if self:IsA("Tool") then
            if k == "Recoil" and Config.NoRecoil then return 0 end
            if k == "Spread" and Config.NoSpread then return 0 end
            if k == "Ammo" and Config.InfAmmo then return math.huge end
            if k == "ReloadTime" and Config.FastReload then return 0 end
            if k == "FireRate" and Config.RapidFire then 
                return 0.15 / Config.FireMultiplier  -- NEW: Normal 0.15s / 2 = 0.075s (2x เร็ว)
            end
            if (k:find("Speed") or k:find("Velocity")) and Config.InstantBullet then return math.huge end
        elseif self:IsA("Mouse") and Config.SilentBullet and (k == "Hit" or k == "Target") then
            local t = GetClosest(Config.SilentFOV, Config.SilentTeamCheck, Config.SilentPart)
            if t then return t.Character[Config.SilentPart].CFrame end
        end
    end
    return oldIndex(self, k)
end)
setreadonly(mt, true)

