-- // Logic Core //
local function GetPlayerStatus(p)
    if p.Team and (p.Team.Name:lower():find("police") or p.Team.Name:lower():find("sheriff")) then return "Police" end
    local stats = p:FindFirstChild("leaderstats")
    local wanted = stats and (stats:FindFirstChild("Wanted") or stats:FindFirstChild("Bounty") or stats:FindFirstChild("Stars"))
    if (wanted and wanted.Value > 0) then return "Criminal" end
    return "Neutral"
end

_RUN.RenderStepped:Connect(function()
    -- No Fog (ทำงานจริง)
    if getgenv().EliteConfig.NoFog then
        _LIGHTING.FogEnd = 100000
        _LIGHTING.FogStart = 100000
        _LIGHTING.ClockTime = 14
        if _LIGHTING:FindFirstChild("Atmosphere") then _LIGHTING.Atmosphere.Density = 0 end
    end

    -- Aim & Auto Shoot
    if getgenv().EliteConfig.AimEnabled then
        local target, shortestMag = nil, getgenv().EliteConfig.FOV
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= _LP and p.Character and p.Character:FindFirstChild(getgenv().EliteConfig.AimPart) and p.Character.Humanoid.Health > 0 then
                local pos, screen = _CAMERA:WorldToViewportPoint(p.Character[getgenv().EliteConfig.AimPart].Position)
                if screen then
                    local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(_CAMERA.ViewportSize.X/2, _CAMERA.ViewportSize.Y/2)).Magnitude
                    if mag < shortestMag then shortestMag = mag; target = p end
                end
            end
        end

        if target then
            local tPart = target.Character[getgenv().EliteConfig.AimPart]
            local dist = (_LP.Character.HumanoidRootPart.Position - tPart.Position).Magnitude
            local predictPos = tPart.Position + (tPart.AssemblyLinearVelocity * (dist / getgenv().EliteConfig.BulletSpeed))
            _CAMERA.CFrame = _CAMERA.CFrame:Lerp(CFrame.new(_CAMERA.CFrame.Position, predictPos + Vector3.new(0, dist/650, 0)), 0.25)
            
            -- ยิงออโต้
            if getgenv().EliteConfig.AutoShoot and shortestMag < 30 then
                _VIM:SendMouseButtonEvent(_CAMERA.ViewportSize.X/2, _CAMERA.ViewportSize.Y/2, 0, true, game, 1)
                task.wait(0.05)
                _VIM:SendMouseButtonEvent(_CAMERA.ViewportSize.X/2, _CAMERA.ViewportSize.Y/2, 0, false, game, 1)
            end
        end
    end
end)

_RUN.Heartbeat:Connect(function()
    -- Vehicle Boost (แบบใหม่ เห็นผลแน่นอน)
    if getgenv().EliteConfig.VehicleBoost then
        local char = _LP.Character
        local seat = char and char:FindFirstChild("Humanoid") and char.Humanoid.SeatPart
        if seat and seat:IsA("VehicleSeat") then
            if seat.Throttle == 1 then
                seat.AssemblyLinearVelocity = seat.CFrame.LookVector * getgenv().EliteConfig.SpeedValue + Vector3.new(0, seat.AssemblyLinearVelocity.Y, 0)
            end
        end
    end

    -- Arrest Assist
    if getgenv().EliteConfig.ArrestAssist then
        local tool = _LP.Character and _LP.Character:FindFirstChildWhichIsA("Tool")
        if tool and tool.Name:lower():find("cuff") then
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= _LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (_LP.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                    if dist <= getgenv().EliteConfig.InteractRange then
                        _VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                    end
                end
            end
        end
    end
end)

-- // ESP //
local function CreateESP(p)
    local txt = Drawing.new("Text"); txt.Size = 16; txt.Outline = true; txt.Center = true; txt.Visible = false
    _RUN.RenderStepped:Connect(function()
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local status = GetPlayerStatus(p)
            local mode = getgenv().EliteConfig.RadarMode
            local show = (mode == "All") or (mode == "Criminals" and status == "Criminal") or (mode == "Police" and status == "Police")
            
            if show then
                local pos, screen = _CAMERA:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                if screen then
                    local d = math.floor((_LP.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude)
                    txt.Position = Vector2.new(pos.X, pos.Y - 45)
                    txt.Color = (status == "Police" and Color3.new(0,0.6,1)) or (status == "Criminal" and Color3.new(1,0,0)) or Color3.new(1,1,1)
                    txt.Text = p.DisplayName .. "\n" .. d .. "m"
                    txt.Visible = true
                else txt.Visible = false end
            else txt.Visible = false end
        else txt.Visible = false end
    end)
end

for _, p in pairs(game.Players:GetPlayers()) do if p ~= _LP then CreateESP(p) end end
game.Players.PlayerAdded:Connect(function(p) if p ~= _LP then CreateESP(p) end end)
