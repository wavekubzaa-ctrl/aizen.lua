-- // CORE LOGIC: CHECK ALIVE //
local function IsAlive(plr)
    if plr and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character:FindFirstChild("HumanoidRootPart") then
        if plr.Character.Humanoid.Health > 0 then
            return true
        end
    end
    return false
end

-- // GET TARGET LOGIC //
local function GetClosestTarget(fov)
    local target = nil
    local maxDist = fov
    
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= _LP and IsAlive(v) then
            if getgenv().DarkElite.SilentTeamCheck and v.Team == _LP.Team then continue end
            
            local pos, vis = _CAMERA:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if vis then
                local mag = (Vector2.new(pos.X, pos.Y) - _UIS:GetMouseLocation()).Magnitude
                if mag < maxDist then
                    maxDist = mag
                    target = v
                end
            end
        end
    end
    return target
end

-- // ESP SYSTEM //
local function CreateESP(plr)
    local Box = Drawing.new("Square")
    Box.Visible = false; Box.Color = Color3.new(1, 0, 0); Box.Thickness = 1; Box.Filled = false
    
    local Name = Drawing.new("Text")
    Name.Visible = false; Name.Color = Color3.new(1, 1, 1); Name.Size = 14; Name.Center = true; Name.Outline = true

    local Connection;
    Connection = _RUN.RenderStepped:Connect(function()
        if getgenv().DarkElite.EnableESP and plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            -- Team Check Logic
            if getgenv().DarkElite.ESP_TeamCheck and plr.Team == _LP.Team then
                Box.Visible = false; Name.Visible = false; return
            end
            -- Dead Check Logic
            if getgenv().DarkElite.ESP_DeadCheck and not IsAlive(plr) then
                Box.Visible = false; Name.Visible = false; return
            end

            local pos, vis = _CAMERA:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
            if vis then
                if getgenv().DarkElite.ESP_Box then
                    Box.Size = Vector2.new(2000 / pos.Z, 2500 / pos.Z)
                    Box.Position = Vector2.new(pos.X - Box.Size.X / 2, pos.Y - Box.Size.Y / 2)
                    Box.Visible = true
                else Box.Visible = false end

                if getgenv().DarkElite.ESP_Name then
                    Name.Text = plr.Name
                    Name.Position = Vector2.new(pos.X, pos.Y - (2500 / pos.Z) / 2 - 15)
                    Name.Visible = true
                else Name.Visible = false end
            else
                Box.Visible = false; Name.Visible = false
            end
        else
            Box.Visible = false; Name.Visible = false
            if not plr or not plr.Parent then
                Box:Remove(); Name:Remove(); Connection:Disconnect()
            end
        end
    end)
end

for _, v in pairs(game.Players:GetPlayers()) do if v ~= _LP then CreateESP(v) end end
game.Players.PlayerAdded:Connect(function(v) CreateESP(v) end)

