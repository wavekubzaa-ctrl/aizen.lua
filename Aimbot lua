local function CreateToggle(text, key)
    local btn = Instance.new("TextButton", Scroll); btn.Size = UDim2.new(1, 0, 0, 38); btn.BackgroundColor3 = Color3.fromRGB(28, 25, 38); btn.Text = "  " .. text .. ": OFF"; btn.TextColor3 = Color3.new(1, 1, 1); btn.TextXAlignment = "Left"; btn.Font = "Gotham"; btn.TextSize = 12; Instance.new("UICorner", btn)
    local function Upd()
        btn.Text = "  " .. text .. (getgenv().DarkElite[key] and ": ON" or ": OFF")
        btn.TextColor3 = getgenv().DarkElite[key] and Color3.fromRGB(160, 80, 255) or Color3.new(1, 1, 1)
    end
    btn.MouseButton1Click:Connect(function() getgenv().DarkElite[key] = not getgenv().DarkElite[key]; Upd() end)
    Upd()
end

