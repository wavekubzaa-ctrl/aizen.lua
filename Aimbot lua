-- // ESP & Targeting Logic //
local ESP_Objects = {}
local function CreateESP(p)
    local nameTag = Drawing.new("Text")
    nameTag.Visible = false; nameTag.Center = true; nameTag.Outline = true; nameTag.Font = 2; nameTag.Size = 13
    ESP_Objects[p] = nameTag
end

for _, p in pairs(game.Players:GetPlayers()) do if p ~= _LP then CreateESP(p) end end
game.Players.PlayerAdded:Connect(function(p) if p ~= _LP then CreateESP(p) end end)
game.Players.PlayerRemoving:Connect(function(p) if ESP_Objects[p] then ESP_Objects[p]:Remove(); ESP_Objects[p] = nil end end)

local function GetTargetable(p)
    if not p.Character or not p.Character:FindFirstChild("Humanoid") or p.Character.Humanoid.Health <= 0 then return false end
    if p.Team == _LP.Team then return false end
    return true
end

-- // Combat Loop //
_RUN.RenderStepped:Connect(function()
    if getgenv().EliteConfig.NoFog then _LIGHTING.FogEnd = 999999; if _LIGHTING:FindFirstChild("Atmosphere") then _LIGHTING.Atmosphere.Density = 0 end end

    -- ESP Rendering
    for p, tag in pairs(ESP_Objects) do
        if getgenv().EliteConfig.ESPEnabled and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local pos, screen = _CAMERA:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if screen then
                local dist = math.floor((_LP.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude)
                tag.Position = Vector2.new(pos.X, pos.Y - 40)
                tag.Text = p.DisplayName .. " [" .. dist .. "m]"
                tag.Color = GetTargetable(p) and Color3.new(1, 0, 0) or Color3.new(1, 1, 1)
                tag.Visible = true
            else tag.Visible = false end
        else tag.Visible = false end
    end

    -- Aimlock & Auto Shoot
    if getgenv().EliteConfig.AimEnabled then
        local tool = _LP.Character and _LP.Character:FindFirstChildWhichIsA("Tool")
        if tool and (tool.Name:lower():find("gun") or tool.Name:lower():find("rifle") or tool.Name:lower():find("glock")) then
            local target, shortestMag = nil, getgenv().EliteConfig.FOV
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= _LP and GetTargetable(p) then
                    local tPart = p.Character:FindFirstChild(getgenv().EliteConfig.AimPart)
                    if tPart then
                        local pos, screen = _CAMERA:WorldToViewportPoint(tPart.Position)
                        if screen then
                            local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(_CAMERA.ViewportSize.X/2, _CAMERA.ViewportSize.Y/2)).Magnitude
                            if mag < shortestMag then shortestMag = mag; target = p end
                        end
                    end
                end
            end
            
            if target then
                local tPart = target.Character[getgenv().EliteConfig.AimPart]
                local dist = (_LP.Character.HumanoidRootPart.Position - tPart.Position).Magnitude
                local predictPos = tPart.Position + (tPart.AssemblyLinearVelocity * (dist / getgenv().EliteConfig.BulletSpeed))
                
                -- Smooth Lerp
                _CAMERA.CFrame = _CAMERA.CFrame:Lerp(CFrame.new(_CAMERA.CFrame.Position, predictPos + Vector3.new(0, dist/750, 0)), getgenv().EliteConfig.Smoothness)
                
                -- Optimized Auto Shoot
                if getgenv().EliteConfig.AutoShoot and shortestMag < 30 then
                    tool:Activate()
                end
            end
        end
    end
end)

-- Vehicle Boost
_RUN.Heartbeat:Connect(function()
    if getgenv().EliteConfig.VehicleBoost then
        local seat = _LP.Character and _LP.Character:FindFirstChild("Humanoid") and _LP.Character.Humanoid.SeatPart
        if seat and seat:IsA("VehicleSeat") and seat.Throttle ~= 0 then
            seat.AssemblyLinearVelocity = seat.CFrame.LookVector * (getgenv().EliteConfig.SpeedValue * seat.Throttle) + Vector3.new(0, seat.AssemblyLinearVelocity.Y, 0)
        end
    end
end)
