_G.Name = "BWH_Elite_V32"

local _MainBtn = Instance.new("TextButton", _G)
_MainBtn.Size = UDim2.new(0, 65, 0, 65)
_MainBtn.Position = UDim2.new(0, 20, 0.4, 0)
_MainBtn.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
