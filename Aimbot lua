-- // ตรวจสอบว่ายังมีชีวิตอยู่ //
local function IsAlive(plr)
    if plr and plr.Character and plr.Character:FindFirstChild("Humanoid") then
        return plr.Character.Humanoid.Health > 0
    end
    return false
end

-- // ค้นหาเป้าหมายที่ใกล้ที่สุด //
local function GetClosestTarget(fov, teamCheck)
    local target = nil
    local maxDist = fov
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= _LP and IsAlive(v) then
            if teamCheck and v.Team == _LP.Team then continue end
            local pos, vis = _CAMERA:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if vis then
                local mag = (Vector2.new(pos.X, pos.Y) - _UIS:GetMouseLocation()).Magnitude
                if mag < maxDist then
                    maxDist = mag
                    target = v
                end
            end
        end
    end
    return target
end

-- // ระบบ ESP //
local function CreateESP(plr)
    local Box = Drawing.new("Square"); Box.Visible = false; Box.Color = Color3.fromRGB(255, 60, 60); Box.Thickness = 1
    local Name = Drawing.new("Text"); Name.Visible = false; Name.Color = Color3.new(1, 1, 1); Name.Size = 14; Name.Center = true; Name.Outline = true
    
    _RUN.RenderStepped:Connect(function()
        if getgenv().Config.EnableESP and plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and IsAlive(plr) then
            if getgenv().Config.ESP_TeamCheck and plr.Team == _LP.Team then Box.Visible = false; Name.Visible = false; return end
            
            local pos, vis = _CAMERA:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
            if vis then
                if getgenv().Config.ESP_Box then
                    Box.Size = Vector2.new(2000 / pos.Z, 2500 / pos.Z)
                    Box.Position = Vector2.new(pos.X - Box.Size.X / 2, pos.Y - Box.Size.Y / 2)
                    Box.Visible = true
                else Box.Visible = false end
                
                if getgenv().Config.ESP_Name then
                    Name.Text = plr.Name
                    Name.Position = Vector2.new(pos.X, pos.Y - (2500 / pos.Z) / 2 - 15)
                    Name.Visible = true
                else Name.Visible = false end
            else Box.Visible = false; Name.Visible = false end
        else Box.Visible = false; Name.Visible = false end
    end)
end

for _, v in pairs(game.Players:GetPlayers()) do if v ~= _LP then CreateESP(v) end end
game.Players.PlayerAdded:Connect(CreateESP)

-- // ระบบประมวลผลหลัก //
_RUN.Heartbeat:Connect(function()
    -- Aimbot Logic
    if getgenv().Config.Aimbot then
        local target = GetClosestTarget(getgenv().Config.AimFOV, true)
        if target and target.Character:FindFirstChild(getgenv().Config.AimPart) then
            local lookAt = CFrame.new(_CAMERA.CFrame.Position, target.Character[getgenv().Config.AimPart].Position)
            _CAMERA.CFrame = _CAMERA.CFrame:Lerp(lookAt, getgenv().Config.AimSmooth)
        end
    end
    
    -- Car Tuning Logic
    if getgenv().Config.CarTuning and _LP.Character and _LP.Character:FindFirstChild("Humanoid") then
        local seat = _LP.Character.Humanoid.SeatPart
        if seat and seat:IsA("VehicleSeat") and seat.Throttle ~= 0 then
            seat.Velocity = seat.CFrame.LookVector * getgenv().Config.CarSpeed
        end
    end
end)

-- // Hooking ระบบปืน //
local mt = getrawmetatable(game); setreadonly(mt, false); local oldNC = mt.__namecall; local oldIDX = mt.__index

mt.__namecall = newcclosure(function(self, ...)
    local args = {...}; local method = getnamecallmethod()
    if getgenv().Config.SilentBullet and method == "FindPartOnRayWithIgnoreList" then
        local target = GetClosestTarget(getgenv().Config.SilentFOV, getgenv().Config.SilentTeamCheck)
        if target and IsAlive(target) then
            args[1] = Ray.new(_CAMERA.CFrame.Position, (target.Character[getgenv().Config.SilentPart].Position - _CAMERA.CFrame.Position).Unit * 1000)
            return oldNC(self, unpack(args))
        end
    end
    return oldNC(self, ...)
end)

mt.__index = newcclosure(function(self, idx)
    if not checkcaller() and self:IsA("Tool") then
        if idx == "Recoil" and getgenv().Config.NoRecoil then return 0 end
        if idx == "MaxSpread" and getgenv().Config.NoSpread then return 0 end
        if idx == "Ammo" and getgenv().Config.InfAmmo then return 999 end
        if idx == "ReloadTime" and getgenv().Config.FastReload then return 0 end
        if idx == "FireRate" and getgenv().Config.RapidFire then return 0.01 end
    end
    return oldIDX(self, idx)
end)
setreadonly(mt, true)

