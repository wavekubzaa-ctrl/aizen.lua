-- // LOGIC: ESP ENGINE //
local function AddESP(p)
    local box = Drawing.new("Square"); box.Visible = false; box.Thickness = 1; box.Filled = false
    local name = Drawing.new("Text"); name.Visible = false; name.Size = 14; name.Center = true; name.Outline = true; name.Color = Color3.new(1,1,1)
    
    _RUN.RenderStepped:Connect(function()
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and getgenv().EliteV88.ESP_Master then
            local pos, vis = _CAMERA:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if vis then
                local root = p.Character.HumanoidRootPart
                local head = p.Character.Head
                local root2d = _CAMERA:WorldToViewportPoint(root.Position)
                local head2d = _CAMERA:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                
                local charSize = (head2d.Y - root2d.Y) * 2
                
                if getgenv().EliteV88.ESP_Box then
                    box.Visible = true
                    box.Size = Vector2.new(1500/pos.Z, charSize)
                    box.Position = Vector2.new(pos.X - box.Size.X/2, pos.Y - box.Size.Y/2)
                    box.Color = (p.Team == _LP.Team) and Color3.new(0,1,0) or Color3.new(1,0,0)
                else box.Visible = false end
                
                if getgenv().EliteV88.ESP_Name or getgenv().EliteV88.ESP_Distance or getgenv().EliteV88.ESP_Health then
                    name.Visible = true
                    local text = ""
                    if getgenv().EliteV88.ESP_Name then text = text .. p.Name .. "\n" end
                    if getgenv().EliteV88.ESP_Health then text = text .. "HP: " .. math.floor(p.Character.Humanoid.Health) .. " " end
                    if getgenv().EliteV88.ESP_Distance then text = text .. "[" .. math.floor((root.Position - _LP.Character.HumanoidRootPart.Position).Magnitude) .. "m]" end
                    name.Text = text
                    name.Position = Vector2.new(pos.X, pos.Y - (box.Size.Y/2) - 25)
                else name.Visible = false end
            else box.Visible = false; name.Visible = false end
        else box.Visible = false; name.Visible = false end
    end)
end

-- // LOGIC: SYSTEMS //
local mt = getrawmetatable(game); setreadonly(mt, false); local oldIndex = mt.__index
mt.__index = newcclosure(function(self, idx)
    if not checkcaller() and self:IsA("Tool") then
        if idx == "Recoil" and getgenv().EliteV88.NoRecoil then return 0 end
        if idx == "MaxSpread" and getgenv().EliteV88.NoSpread then return 0 end
        if idx == "Ammo" and getgenv().EliteV88.InfAmmo then return 999 end
        if idx == "Delay" and getgenv().EliteV88.RapidFire then return 0.05 end
    end
    return oldIndex(self, idx)
end)
setreadonly(mt, true)

SetPlateBtn.MouseButton1Click:Connect(function()
    local char = _LP.Character
    if char and char.Humanoid.SeatPart then
        local car = char.Humanoid.SeatPart.Parent
        for _, v in pairs(car:GetDescendants()) do
            if (v:IsA("TextLabel") or v:IsA("TextBox")) and (v.Name:lower():find("plate") or v.Name:lower():find("text")) then
                v.Text = PlateInput.Text
            end
        end
    end
end)

_RUN.Stepped:Connect(function()
    local char = _LP.Character
    if char and char:FindFirstChild("Humanoid") then
        if getgenv().EliteV88.AutoHeal and char.Humanoid.Health > 0 and char.Humanoid.Health < getgenv().EliteV88.HealThreshold then
            char.HumanoidRootPart.CFrame = CFrame.new(getgenv().EliteV88.HealPos)
            task.wait(0.5)
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ProximityPrompt") and (v.Parent.Position - char.HumanoidRootPart.Position).Magnitude < 10 then fireproximityprompt(v) end
            end
        end
        if getgenv().EliteV88.InfStamina then char.Humanoid.WalkSpeed = getgenv().EliteV88.WalkSpeed end
        if getgenv().EliteV88.NoClip then for _, part in pairs(char:GetChildren()) do if part:IsA("BasePart") then part.CanCollide = false end end end
        local seat = char.Humanoid.SeatPart
        if seat and getgenv().EliteV88.CarTuning and seat.Throttle ~= 0 then
            seat.Velocity = seat.CFrame.LookVector * (seat.Throttle * getgenv().EliteV88.TopSpeed)
        end
    end
end)

