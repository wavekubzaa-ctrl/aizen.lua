-- // Targeting Logic //
local function IsPolice(p)
    return p.Team and (p.Team.Name:lower():find("police") or p.Team.Name:lower():find("sheriff"))
end

local function GetTargetable(p)
    if not p.Character or not p.Character:FindFirstChild("Humanoid") or p.Character.Humanoid.Health <= 0 then return false end
    if p.Team == _LP.Team then return false end

    if IsPolice(_LP) then
        local stats = p:FindFirstChild("leaderstats")
        local wanted = stats and (stats:FindFirstChild("Wanted") or stats:FindFirstChild("Bounty") or stats:FindFirstChild("Stars"))
        local hasWanted = wanted and wanted.Value > 0
        local hasGun = p.Character:FindFirstChildWhichIsA("Tool") and (p.Character:FindFirstChildWhichIsA("Tool").Name:lower():find("gun") or p.Character:FindFirstChildWhichIsA("Tool").Name:lower():find("rifle"))
        return hasWanted or hasGun
    else
        return true
    end
end

