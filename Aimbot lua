local _UIS = game:GetService("UserInputService")
local _RUN = game:GetService("RunService")

-- // ระบบตรวจสอบสถานะตัวละคร (ไม่ล็อกคนตาย) //
local function IsAlive(plr)
    if plr and plr.Character and plr.Character:FindFirstChild("Humanoid") then
        return plr.Character.Humanoid.Health > 0
    end
    return false
end

-- // ระบบค้นหาเป้าหมาย //
local function GetClosestTarget(fov, teamCheck)
    local target = nil
    local maxDist = fov
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= _LP and IsAlive(v) then
            if teamCheck and v.Team == _LP.Team then continue end
            local screenPos, onScreen = _CAMERA:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if onScreen then
                local mag = (Vector2.new(screenPos.X, screenPos.Y) - _UIS:GetMouseLocation()).Magnitude
                if mag < maxDist then
                    maxDist = mag
                    target = v
                end
            end
        end
    end
    return target
end

-- // ระบบการทำงานหลัก (Main Loops) //
_RUN.RenderStepped:Connect(function()
    -- ระบบล็อกเป้า (Aimbot)
    if getgenv().Config.Aimbot then
        local target = GetClosestTarget(getgenv().Config.AimFOV, true)
        if target and IsAlive(target) and target.Character:FindFirstChild(getgenv().Config.Config.AimPart) then
            local targetPos = target.Character[getgenv().Config.AimPart].Position
            local lookAt = CFrame.new(_CAMERA.CFrame.Position, targetPos)
            _CAMERA.CFrame = _CAMERA.CFrame:Lerp(lookAt, getgenv().Config.AimSmooth)
        end
    end
    
    -- ระบบฮีลอัตโนมัติ (Auto Heal)
    if getgenv().Config.AutoHeal then
        local hum = (_LP.Character and _LP.Character:FindFirstChild("Humanoid"))
        if hum and hum.Health > 0 and hum.Health < getgenv().Config.HealThreshold then
            _LP.Character.HumanoidRootPart.CFrame = CFrame.new(getgenv().Config.HealPos)
            getgenv().Config.AutoHeal = false
            Rayfield:Notify({Title = "ระบบฮีล", Content = "วาร์ปไปรักษาตัวที่เตียงเรียบร้อย", Duration = 3})
        end
    end
end)

-- // ระบบม็อดปืน (Gun Mod Engines) //
local mt = getrawmetatable(game); setreadonly(mt, false)
local oldNamecall = mt.__namecall; local oldIndex = mt.__index

mt.__namecall = newcclosure(function(self, ...)
    local args = {...}; local method = getnamecallmethod()
    if not checkcaller() and getgenv().Config.SilentBullet and method == "FindPartOnRayWithIgnoreList" then
        local target = GetClosestTarget(getgenv().Config.SilentFOV, getgenv().Config.SilentTeamCheck)
        if target and IsAlive(target) then
            local partName = getgenv().Config.SilentPart
            args[1] = Ray.new(_CAMERA.CFrame.Position, (target.Character[partName].Position - _CAMERA.CFrame.Position).Unit * 1000)
            return oldNamecall(self, unpack(args))
        end
    end
    return oldNamecall(self, ...)
end)

mt.__index = newcclosure(function(self, idx)
    if not checkcaller() and self:IsA("Tool") then
        if idx == "Recoil" and getgenv().Config.NoRecoil then return 0 end
        if idx == "MaxSpread" and getgenv().Config.NoSpread then return 0 end
        if idx == "Ammo" and getgenv().Config.InfAmmo then return 999 end
        if idx == "ReloadTime" and getgenv().Config.FastReload then return 0 end
        if idx == "FireRate" and getgenv().Config.RapidFire then return 0.01 end
    end
    return oldIndex(self, idx)
end)
setreadonly(mt, true)

