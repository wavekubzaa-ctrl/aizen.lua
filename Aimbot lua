-- ฟังก์ชันพื้นฐาน (เหมือนเดิม)
local function IsAlive(plr)
    local c = plr.Character
    return c and c:FindFirstChild("Humanoid") and c.Humanoid.Health > 0
end

local function GetClosest(fov, teamCheck, partName)
    local t, md = nil, fov
    for _, p in ipairs(Players:GetPlayers()) do
        if p \~= LP and IsAlive(p) and (not teamCheck or p.Team \~= LP.Team) then
            local part = p.Character and p.Character:FindFirstChild(partName or "Head")
            if part then
                local pos, on = Camera:WorldToViewportPoint(part.Position)
                if on then
                    local d = (Vector2.new(pos.X, pos.Y) - UIS:GetMouseLocation()).Magnitude
                    if d < md then md, t = d, p end
                end
            end
        end
    end
    return t
end

-- ESP (เหมือนเดิม)
local ESPs = {}
local function AddESP(p)
    if p == LP then return end
    local d = {}
    d.Box = Drawing.new("Square"); d.Box.Thickness = 1; d.Box.Filled = false
    d.Name = Drawing.new("Text"); d.Name.Size = 14; d.Name.Center = true; d.Name.Outline = true; d.Name.Font = 2
    if not Config.LowQuality then
        d.HPBG = Drawing.new("Square"); d.HPBG.Filled = true; d.HPBG.Color = Color3.new(0,0,0)
        d.HPF = Drawing.new("Square"); d.HPF.Filled = true
        d.HPT = Drawing.new("Text"); d.HPT.Size = 12; d.HPT.Outline = true
        d.Dist = Drawing.new("Text"); d.Dist.Size = 12; d.Dist.Outline = true
    end
    ESPs[p] = d
end

local function RemESP(p)
    if ESPs[p] then for _,o in pairs(ESPs[p]) do o:Remove() end; ESPs[p] = nil end
end

local function UpESP()
    for p, d in pairs(ESPs) do
        if not IsAlive(p) or (Config.ESP_TeamCheck and p.Team == LP.Team) then
            for _,o in pairs(d) do o.Visible = false end continue
        end
        local root = p.Character.HumanoidRootPart
        local dist = (LP.Character.HumanoidRootPart.Position - root.Position).Magnitude
        if dist > Config.MaxDist then for _,o in pairs(d) do o.Visible = false end continue end
        local pos, v = Camera:WorldToViewportPoint(root.Position)
        if not v then for _,o in pairs(d) do o.Visible = false end continue end
        local h = math.clamp(500 / pos.Z, 20, 180)
        local w = h * 0.6
        local col = (p.Team == LP.Team) and Color3.new(0,1,0) or Color3.new(1,0,0)
        
        if Config.ESP_Box then
            d.Box.Size = Vector2.new(w, h)
            d.Box.Position = Vector2.new(pos.X - w/2, pos.Y - h/2)
            d.Box.Color = col
            d.Box.Visible = true
        else d.Box.Visible = false end
        
        if Config.ESP_NameTeam then
            d.Name.Text = p.Name .. (p.Team and " ["..p.Team.Name.."]" or "")
            d.Name.Position = Vector2.new(pos.X, pos.Y - h/2 - 20)
            d.Name.Color = col
            d.Name.Visible = true
        else d.Name.Visible = false end
        
        if not Config.LowQuality then
            local hum = p.Character.Humanoid
            local hp = hum.Health / hum.MaxHealth
            local by = pos.Y + h/2 + 5
            if Config.ESP_HPBar then
                d.HPBG.Position = Vector2.new(pos.X-6, by); d.HPBG.Size = Vector2.new(4,20); d.HPBG.Visible = true
                d.HPF.Size = Vector2.new(2,18*hp); d.HPF.Position = Vector2.new(pos.X-5, by+18*(1-hp))
                d.HPF.Color = Color3.new(1-hp, hp, 0); d.HPF.Visible = true
            end
            if Config.ESP_HPTxt then
                d.HPT.Text = math.floor(hum.Health).."/"..hum.MaxHealth
                d.HPT.Position = Vector2.new(pos.X, by+10)
                d.HPT.Color = d.HPF.Color
                d.HPT.Visible = true
            end
            if Config.ESP_Dist then
                d.Dist.Text = math.floor(dist*0.28).."m"
                d.Dist.Position = Vector2.new(pos.X, by+30)
                d.Dist.Visible = true
            end
        end
    end
end

for _,v in ipairs(Players:GetPlayers()) do AddESP(v) end
