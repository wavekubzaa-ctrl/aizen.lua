local function IsAlive(plr)
    local c = plr.Character
    return c and c:FindFirstChild("Humanoid") and c.Humanoid.Health > 0
end

local function GetClosest(fov, teamCheck, partName)
    local t, md = nil, fov
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and IsAlive(p) and (not teamCheck or p.Team ~= LP.Team) then
            local part = p.Character and p.Character:FindFirstChild(partName or "Head")
            if part then
                local pos, on = Camera:WorldToViewportPoint(part.Position)
                if on then
                    local mousePos = UIS:GetMouseLocation() or Vector2.new(0,0)
                    local d = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if d < md then md, t = d, p end
                end
            end
        end
    end
    return t
end

-- ESP (สีทีม + เมตร + แก้ nil)
local ESPs = {}
local function AddESP(p)
    if p == LP then return end
    local d = {}
    d.Box = Drawing.new("Square"); d.Box.Thickness = 1; d.Box.Filled = false
    d.Name = Drawing.new("Text"); d.Name.Size = 14; d.Name.Center = true; d.Name.Outline = true; d.Name.Font = 2
    d.Dist = Drawing.new("Text"); d.Dist.Size = 12; d.Dist.Outline = true
    ESPs[p] = d
end

local function RemESP(p)
    if ESPs[p] then for _,o in pairs(ESPs[p]) do o:Remove() end; ESPs[p] = nil end
end

local function UpESP()
    for p, d in pairs(ESPs) do
        if not IsAlive(p) or (Config.ESP_TeamCheck and p.Team == LP.Team) then
            for _,o in pairs(d) do o.Visible = false end continue
        end
        local char = p.Character
        if not char then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root or not root.Position then continue end
        
        local dist = (LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") and (LP.Character.HumanoidRootPart.Position - root.Position).Magnitude) or 9999
        if dist > Config.MaxDist then for _,o in pairs(d) do o.Visible = false end continue end
        
        local pos, v = Camera:WorldToViewportPoint(root.Position)
        if not v then for _,o in pairs(d) do o.Visible = false end continue end
        
        local h = math.clamp(500 / pos.Z, 20, 180)
        local w = h * 0.6
        
        local teamColor = Color3.new(1,1,1)
        if p.Team then
            local tn = p.Team.Name:lower()
            if tn:find("police") or tn:find("cop") or tn:find("emergency") or tn:find("notruf") then teamColor = Color3.fromRGB(0,100,255)
            elseif tn:find("robber") or tn:find("criminal") or tn:find("thief") then teamColor = Color3.fromRGB(255,0,0) end
        end
        
        if Config.ESP_Box then d.Box.Size = Vector2.new(w,h); d.Box.Position = Vector2.new(pos.X-w/2,pos.Y-h/2); d.Box.Color = teamColor; d.Box.Visible = true end
        if Config.ESP_NameTeam then d.Name.Text = p.Name..(p.Team and " ["..p.Team.Name.."]" or ""); d.Name.Position = Vector2.new(pos.X,pos.Y-h/2-20); d.Name.Color = teamColor; d.Name.Visible = true end
        if Config.ESP_Dist then d.Dist.Text = math.floor(dist).."m"; d.Dist.Position = Vector2.new(pos.X,pos.Y+h/2+10); d.Dist.Color = teamColor; d.Dist.Visible = true end
    end
end

for _,v in ipairs(Players:GetPlayers()) do AddESP(v) end
Players.PlayerAdded:Connect(AddESP)
Players.PlayerRemoving:Connect(RemESP)
RS.Heartbeat:Connect(UpESP)

-- Hooks (pcall wrap เพื่อไม่ spam error)
local mt = getrawmetatable(game)
setreadonly(mt, false)
local oldNamecall = mt.__namecall
mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    pcall(function()
        if Config.SilentBullet and self == WS and method == "Raycast" then
            local dir = args[2]
            if dir.Magnitude < 50 then return oldNamecall(self, ...) end
            local target = GetClosest(Config.SilentFOV, Config.SilentTeamCheck, Config.SilentPart)
            if target and math.random(1,100) <= Config.HitChance then
                local tp = target.Character[Config.SilentPart].Position + (target.Character.HumanoidRootPart.Velocity * 0.135)
                args[2] = (tp - args[1]).Unit * dir.Magnitude
            end
        end
    end)
    return oldNamecall(self, unpack(args))
end)

local oldIndex = mt.__index
mt.__index = newcclosure(function(self, key)
    if not checkcaller() then
        pcall(function()
            if self:IsA("Tool") then
                if key == "Recoil" and Config.NoRecoil then return 0 end
                if key == "Spread" and Config.NoSpread then return 0 end
                if key == "Ammo" and Config.InfAmmo then return math.huge end
                if key == "ReloadTime" and Config.FastReload then return 0 end
                if key == "FireRate" and Config.RapidFire then return 0.15 / Config.FireMultiplier end
                if (key:find("Speed") or key:find("Velocity")) and Config.InstantBullet then return math.huge end
            end
        end)
    end
    return oldIndex(self, key)
end)
setreadonly(mt, true)

