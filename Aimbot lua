_Panel.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
_Panel.Visible = false
Instance.new("UICorner", _Panel)

local function AddBtn(text, y, callback, color)
    local b = Instance.new("TextButton", _Panel)
    b.Size = UDim2.new(0.9, 0, 0, 25)
    b.Position = UDim2.new(0.05, 0, 0, y)
    b.BackgroundColor3 = color or Color3.fromRGB(25, 25, 25)
    b.Text = text; b.TextColor3 = Color3.new(0.9, 0.9, 0.9)
    b.Font = Enum.Font.GothamMedium; b.TextSize = 10
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function() callback(b) end)
    return b
end

