local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local UIS = game:GetService("UserInputService")
local RS = game:GetService("RunService")

-- // ฟังก์ชันตรวจสอบว่ายังมีชีวิตอยู่หรือไม่ //
local function IsAlive(plr)
    local char = plr.Character
    if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") then
        if getgenv().TacticalConfig.DeadCheck and char.Humanoid.Health <= 0 then
            return false
        end
        return true
    end
    return false
end

-- // ฟังก์ชันค้นหาเป้าหมายที่อยู่ใกล้กึ่งกลางจอมากที่สุดใน FOV //
local function GetClosestTarget()
    local target = nil
    local maxDist = getgenv().TacticalConfig.AimFOV
    
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= LP and IsAlive(v) then
            -- ระบบคัดกรองทีม (Team Check)
            if getgenv().TacticalConfig.TeamCheck and v.Team == LP.Team then continue end
            
            local part = v.Character:FindFirstChild(getgenv().TacticalConfig.AimPart)
            if part then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mag = (Vector2.new(screenPos.X, screenPos.Y) - UIS:GetMouseLocation()).Magnitude
                    if mag < maxDist then
                        maxDist = mag
                        target = v
                    end
                end
            end
        end
    end
    return target
end

-- // ระบบ ESP (วาดเฟรมสด) //
local ESP_Storage = {}

local function CreateESP(plr)
    if plr == LP then return end
    
    local d = {}
    d.Box = Drawing.new("Square")
    d.Box.Thickness = 1.5
    d.Box.Filled = false
    d.Box.Visible = false
    
    d.Name = Drawing.new("Text")
    d.Name.Size = 13
    d.Name.Center = true
    d.Name.Outline = true
    d.Name.Visible = false
    
    ESP_Storage[plr] = d
end

local function RemoveESP(plr)
    if ESP_Storage[plr] then
        for _, obj in pairs(ESP_Storage[plr]) do
            obj:Remove()
        end
        ESP_Storage[plr] = nil
    end
end

-- อัปเดตตำแหน่ง ESP บนหน้าจอ
RS.RenderStepped:Connect(function()
    for plr, d in pairs(ESP_Storage) do
        if getgenv().TacticalConfig.ESPEnabled and IsAlive(plr) then
            -- เช็คคัดกรองทีมใน ESP
            if getgenv().TacticalConfig.ESP_TeamCheck and plr.Team == LP.Team then
                d.Box.Visible = false
                d.Name.Visible = false
                continue
            end
            
            local root = plr.Character.HumanoidRootPart
            local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
            
            if onScreen then
                local height = math.clamp(1000 / screenPos.Z, 30, 250)
                local width = height * 0.6
                local col = (plr.Team == LP.Team) and Color3.new(0, 1, 0) or Color3.new(1, 0.2, 0.2)
                
                -- อัปเดตสี่เหลี่ยมรอบตัว (Box)
                if getgenv().TacticalConfig.ESP_Box then
                    d.Box.Size = Vector2.new(width, height)
                    d.Box.Position = Vector2.new(screenPos.X - width / 2, screenPos.Y - height / 2)
                    d.Box.Color = col
                    d.Box.Visible = true
                else
                    d.Box.Visible = false
                end
                
                -- อัปเดตแสดงชื่อ (Name)
                if getgenv().TacticalConfig.ESP_Name then
                    d.Name.Text = plr.Name .. " [" .. math.floor(plr.Character.Humanoid.Health) .. " HP]"
                    d.Name.Position = Vector2.new(screenPos.X, screenPos.Y - height / 2 - 18)
                    d.Name.Color = col
                    d.Name.Visible = true
                else
                    d.Name.Visible = false
                end
            else
                d.Box.Visible = false
                d.Name.Visible = false
            end
        else
            d.Box.Visible = false
            d.Name.Visible = false
        end
    end
end)

-- โหลดรายชื่อผู้เล่นเพื่อเปิด ESP
for _, v in ipairs(Players:GetPlayers()) do CreateESP(v) end
Players.PlayerAdded:Connect(CreateESP)
Players.PlayerRemoving:Connect(RemoveESP)

-- // ระบบประมวลผลหมุนกล้องติดตาม (Aimbot Loop) //
RS.RenderStepped:Connect(function()
    if getgenv().TacticalConfig.AimbotEnabled then
        local target = GetClosestTarget()
        if target and target.Character:FindFirstChild(getgenv().TacticalConfig.AimPart) then
            local targetPos = target.Character[getgenv().TacticalConfig.AimPart].Position
            local lookAt = CFrame.lookAt(Camera.CFrame.Position, targetPos)
            
            -- ปรับมุมกล้องให้หันหน้าตามแบบสมูท (Lerp) เพื่อความธรรมชาติ
            Camera.CFrame = Camera.CFrame:Lerp(lookAt, getgenv().TacticalConfig.Smoothness)
        end
    end
end)

